{
  "name": "gitferret",
  "version": "0.1.0",
  "description": "Gitferret - AI-powered CLI tool for reviewing pull requests and understanding codebases.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "gitferret": "dist/index.js"
  },
  "files": [
    "dist/",
    "gitferret.config.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --enable-source-maps --watch dist/index.js",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.1",
    "dotenv": "^17.2.2",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
